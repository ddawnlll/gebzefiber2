<%- include('partials/head', { title: 'Sayfalar' }) %>
<body>
  <div class="grain" aria-hidden="true"></div>
  <div class="layout">
    <%- include('partials/sidebar', { active: 'pages' }) %>

    <main class="main">
      <%- include('partials/topbar', {
        eyebrow: 'Analitik',
        heading: 'Sayfa Performansı',
        sub: 'Hangi sayfa tutuyor, hangisi kaçırıyor',
        range, path: '/admin/pages'
      }) %>

      <section class="card">
        <div class="card-head">
          <h3>Sayfa Detayı</h3>
          <span class="card-note"><%= range.label %> · başlığa tıklayarak sırala</span>
        </div>
        <% if (pages.length === 0) { %>
          <div class="empty-state">
            <svg viewBox="0 0 48 24" width="72" aria-hidden="true"><path d="M2 18 C 12 4, 22 22, 46 8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-dasharray="3 4"/></svg>
            <p>Bu aralıkta görüntüleme yok.</p>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <table class="table" data-sortable>
              <thead>
                <tr>
                  <th>Sayfa</th>
                  <th data-sort="num" class="is-sorted">Görüntüleme <span class="sort-ico"></span></th>
                  <th data-sort="num">Tekil <span class="sort-ico"></span></th>
                  <th data-sort="num">Ort. Süre <span class="sort-ico"></span></th>
                  <th data-sort="num">Çıkma <span class="sort-ico"></span></th>
                  <th data-sort="num">Dönüşüm <span class="sort-ico"></span></th>
                  <th data-sort="num">Oran <span class="sort-ico"></span></th>
                </tr>
              </thead>
              <tbody>
                <% pages.forEach(p => { %>
                  <tr>
                    <td>
                      <code class="td-path" title="<%= p.title || p.path %>"><%= p.path %></code>
                      <div class="cell-bar"><i style="width:<%= Math.max(3, p.share) %>%"></i></div>
                    </td>
                    <td data-v="<%= p.views %>"><%= p.views %></td>
                    <td data-v="<%= p.uniques %>"><%= p.uniques %></td>
                    <td data-v="<%= Math.round(p.avg_time || 0) %>"><%= Math.round(p.avg_time || 0) %>s</td>
                    <td data-v="<%= p.bounce_rate %>">
                      <span class="bounce <%= p.bounce_rate >= 70 ? 'bounce--bad' : p.bounce_rate >= 40 ? 'bounce--mid' : 'bounce--good' %>">%<%= p.bounce_rate %></span>
                    </td>
                    <td data-v="<%= p.conversions %>"><strong class="t-amber"><%= p.conversions %></strong></td>
                    <td data-v="<%= p.rate %>">%<%= p.rate %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </main>
  </div>
</body>
</html>
