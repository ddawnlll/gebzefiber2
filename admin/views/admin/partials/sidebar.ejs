      <path d="M2 22 C 10 6, 18 28, 30 10" fill="none" stroke="url(#sbGrad)" stroke-width="2.4" stroke-linecap="round"/>
      <circle class="brand-pulse" cx="21" cy="21.4" r="3" fill="#ffb25e"/>
      <defs>
        <linearGradient id="sbGrad" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#6bf0c2"/>
          <stop offset="1" stop-color="#9d8cff"/>
        </linearGradient>
      </defs>
    </svg>
    <span class="sidebar-brand-name">Gebze <em>Fiber</em><small>Yönetim Paneli</small></span>
  </a>

